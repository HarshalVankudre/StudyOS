// StudyOS database schema.
// Postgres (Neon) for development and production. `DATABASE_URL` is the pooled
// connection used at runtime; `DATABASE_URL_UNPOOLED` is the direct connection
// used for migrations / `prisma db push`.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  // "native" keeps local dev (Windows) working; "debian-openssl-3.0.x" is the
  // query-engine binary for the node:22-slim (Debian bookworm) Cloud Run image.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A saved workspace. The full workspace tree is stored as JSON in `data`;
// `name`/`icon` are denormalized so we can list workspaces without parsing it.
// `ownerId` defaults to "local" until real auth (Clerk) is added.
model Workspace {
  id        String   @id
  ownerId   String   @default("local")
  name      String
  icon      String?
  data      String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  changes   WorkspaceChange[]

  @@index([ownerId])
}

// Append-only history of agent (and undo) edits to a workspace. Each row keeps
// the exact before/after snapshots and the version each one moved between, so an
// agent change can be atomically reverted without trusting client-supplied JSON.
model WorkspaceChange {
  id            String    @id @default(cuid())
  workspaceId   String
  ownerId       String
  kind          String    @default("agent")
  beforeData    String
  afterData     String
  beforeVersion Int
  afterVersion  Int
  undoneAt      DateTime?
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, afterVersion])
  @@index([workspaceId, ownerId, createdAt])
}

// A durable, owner-scoped record of one agent task. Survives a disconnect so the
// user can reconnect and receive the result, and carries a cancel flag the apply
// step consults before committing. `result` holds the final stream payload;
// rows expire ~10 minutes after creation.
model AgentTask {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  baseVersion Int
  status      String   @default("running")
  result      String?
  error       String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, workspaceId])
}

// One row per user (Clerk user id) tracking their Stripe subscription.
model Subscription {
  userId               String    @id
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String    @default("free")
  currentPeriodEnd     DateTime?
  updatedAt            DateTime  @updatedAt
}

// A user's AI credit balance. Credits are spent per AI request based on the
// GLM 5.2 tokens it actually used (see lib/credits.ts).
model CreditAccount {
  userId    String   @id
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only audit trail of every credit change (grant, purchase, usage).
// `idempotencyKey` makes grants safe to retry (Stripe webhook + success redirect).
model CreditLedger {
  id             String   @id @default(cuid())
  userId         String
  delta          Int
  reason         String
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())

  @@index([userId])
}
